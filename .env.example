# API settings. Copy to .env for local use; never commit real secrets.
MSME_SAARTHI_ENVIRONMENT=local
MSME_SAARTHI_DEBUG=false
MSME_SAARTHI_LOG_LEVEL=INFO
MSME_SAARTHI_DATABASE_URL=postgresql+asyncpg://msme_saarthi:local-development-only@127.0.0.1:5432/msme_saarthi
# Generate with: openssl rand -base64 32
MSME_SAARTHI_DATA_ENCRYPTION_KEY=
MSME_SAARTHI_DATA_ENCRYPTION_KEY_VERSION=v1
MSME_SAARTHI_WEB_ORIGIN=http://127.0.0.1:5173
MSME_SAARTHI_SESSION_COOKIE_SECURE=false
# Use mock without a key; set openai only in a secure server-side environment.
MSME_SAARTHI_LLM_PROVIDER=mock
MSME_SAARTHI_OPENAI_API_KEY=
MSME_SAARTHI_OPENAI_MODEL=gpt-5.4-mini
MSME_SAARTHI_OPENAI_IMAGE_MODEL=gpt-image-2
MSME_SAARTHI_OPENAI_BASE_URL=https://api.openai.com/v1
MSME_SAARTHI_LLM_TIMEOUT_SECONDS=30
MSME_SAARTHI_IMAGE_GENERATION_TIMEOUT_SECONDS=120
MSME_SAARTHI_RETRIEVAL_PROVIDER=opensearch
MSME_SAARTHI_EMBEDDING_PROVIDER=local
MSME_SAARTHI_EMBEDDING_MODEL=text-embedding-3-small
MSME_SAARTHI_EMBEDDING_DIMENSIONS=384
MSME_SAARTHI_OPENSEARCH_URL=http://127.0.0.1:9200
MSME_SAARTHI_OPENSEARCH_INDEX=msme-schemes-v2
# Retrieval fails closed when indexed sources lack capture metadata or exceed these ages.
MSME_SAARTHI_RETRIEVAL_OFFICIAL_MAX_AGE_DAYS=90
MSME_SAARTHI_RETRIEVAL_GUIDE_MAX_AGE_DAYS=3650
MSME_SAARTHI_RETRIEVAL_RRF_RANK_CONSTANT=60
MSME_SAARTHI_RETRIEVAL_RRF_LEXICAL_WEIGHT=0.8
MSME_SAARTHI_RETRIEVAL_RRF_VECTOR_WEIGHT=1.0
MSME_SAARTHI_RETRIEVAL_RRF_MAX_CHUNKS_PER_DOCUMENT=1
